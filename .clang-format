---
BasedOnStyle: LLVM
Language: Cpp
Standard: c++20
AlwaysBreakTemplateDeclarations: Yes
InsertBraces: Yes
IncludeCategories:
  - Regex:           '^<.*\.h>'
    Priority:        1
    SortPriority:    0
    CaseSensitive:   false
  - Regex:           '^<.*'
    Priority:        2
    SortPriority:    0
    CaseSensitive:   false
  - Regex:           '.*'
    Priority:        3
    SortPriority:    0
    CaseSensitive:   false
